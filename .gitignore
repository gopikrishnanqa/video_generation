# Large FFmpeg.wasm binaries — restored by: npm install (postinstall script)
# Required after clone: public/vendor/ffmpeg/ffmpeg.js, 814.ffmpeg.js, ffmpeg-core.js, ffmpeg-core.wasm
/public/vendor/ffmpeg/*
!/public/vendor/ffmpeg/README.md

# Optional: ignore root-level media dumps (assets live under public/media/)
/*.mp3
/*.wav
/*.mp4
/*.png
/*.jpg
/*.jpeg
/*.webp

# Keep these tracked (do NOT add rules above for):
# - app/, lib/, scripts/
# - public/samples/          (poster images)
# - public/media/music/      (MP3/WAV)
# - public/media/reference-videos/  (optional reference MP4s)
# - package.json, package-lock.json, next.config.ts, tsconfig.json, vercel.json
