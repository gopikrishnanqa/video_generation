# Treat media and wasm as binary (no line-ending or merge diffs)
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.gif binary
*.mp3 binary
*.wav binary
*.mp4 binary
*.webm binary
*.wasm binary

# Normalize text files
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
*.css text eol=lf
